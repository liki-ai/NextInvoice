{
  "expo": {
    "name": "NextInvoice",
    "slug": "nextinvoice",
    "version": "1.0.7",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2C6E7F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lirim123.nextinvoice",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryUsageDescription": "NextInvoice needs access to your photos so you can import a sample invoice image.",
        "NSCameraUsageDescription": "NextInvoice needs camera access so you can photograph a sample invoice."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.lirim123.nextinvoice"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-document-picker",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "ac954ef6-cf98-46bc-8811-41ae697dc89d"
      }
    },
    "owner": "lirim123"
  }
}
